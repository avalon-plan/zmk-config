#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/led/led.h>
#include <dt-bindings/pinctrl/nrf-pinctrl.h>
#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/*
 * 引脚(XIAO/Super52840 焊盘):
 *   I2C  SDA=P0.04(D4)  SCL=P0.05(D5)  -> AS5600(滚动)
 *   SPI3 MOSI=P1.12(D7)                 -> WS2812B DIN
 *   按键 P0.02(D0)=切层键  P0.03(D1)=蓝牙键(都接 GND)
 *   复位 = 硬件 RST↔GND
 */

&pinctrl {
    as5600_i2c_default: as5600_i2c_default {
        group1 { psels = <NRF_PSEL(TWIM_SDA, 0, 4)>, <NRF_PSEL(TWIM_SCL, 0, 5)>; };
    };
    as5600_i2c_sleep: as5600_i2c_sleep {
        group1 { psels = <NRF_PSEL(TWIM_SDA, 0, 4)>, <NRF_PSEL(TWIM_SCL, 0, 5)>; low-power-enable; };
    };
    ws2812_spi_default: ws2812_spi_default {
        group1 { psels = <NRF_PSEL(SPIM_MOSI, 1, 12)>; };
    };
    ws2812_spi_sleep: ws2812_spi_sleep {
        group1 { psels = <NRF_PSEL(SPIM_MOSI, 1, 12)>; low-power-enable; };
    };
};

&i2c0 {
    compatible = "nordic,nrf-twi";
    pinctrl-0 = <&as5600_i2c_default>;
    pinctrl-1 = <&as5600_i2c_sleep>;
    pinctrl-names = "default", "sleep";
    status = "okay";

    as5600: as5600@36 {
        compatible = "zmk,input-ams-as5600";
        reg = <0x36>;
        status = "okay";
    };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&ws2812_spi_default>;
    pinctrl-1 = <&ws2812_spi_sleep>;
    pinctrl-names = "default", "sleep";
    status = "okay";

    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <1>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

/ {
    chosen {
        zmk,kscan = &default_kscan;
        zmk,physical-layout = &physical_layout0;
        zmk,underglow = &led_strip;
        /* 注意:用 Studio 时不要再设 zmk,matrix-transform,交给 physical-layout */
    };

    default_kscan: kscan {
        compatible = "zmk,kscan-gpio-direct";
        label = "default_kscan";
        input-gpios =
            <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>,   /* key0 = 切层键 */
            <&gpio0 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;   /* key1 = 蓝牙键 */
    };

    /* ZMK Studio 需要的矩阵变换 + 物理布局(2 个键) */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <2>;
        rows = <1>;
        map = <RC(0,0) RC(0,1)>;
    };

    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Knob Macropad";
        transform = <&default_transform>;
        keys
            = <&key_physical_attrs 100 100    0   0 0 0 0>
            , <&key_physical_attrs 100 100  100   0 0 0 0>
            ;
    };
    /* AS5600 的监听器 + 分层输入处理器在 keymap 文件里 */
};
